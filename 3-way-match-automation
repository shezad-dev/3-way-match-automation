#!/usr/bin/env python3
"""
3-Way Match System - Checks POs against delivery notes and invoices
Runs 2 times, sends all mismatches via email
"""

import urllib.request
import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart
import time
from datetime import datetime
import os

# ============ CONFIG ============

SHEET_ID = "1k1Hek8UbGDbg5s4MGBAGov1Tap0bGSjSS1kWtfcw0wQ"

# Get credentials from config file if it exists
try:
    from config import GMAIL_USER, GMAIL_PASSWORD, ALERT_EMAIL
except ImportError:
    # Fallback to environment variables
    GMAIL_USER = os.environ.get('GMAIL_USER')
    GMAIL_PASSWORD = os.environ.get('GMAIL_PASSWORD')
    ALERT_EMAIL = os.environ.get('ALERT_EMAIL')
    
    if not all([GMAIL_USER, GMAIL_PASSWORD, ALERT_EMAIL]):
        print("ERROR: Missing credentials!")
        print("Create config.py with GMAIL_USER, GMAIL_PASSWORD, ALERT_EMAIL")
        exit(1)

TOTAL_RUNS = 2
RUN_INTERVAL = 60

# ============ READ SHEET ============

def read_sheet(sheet_name):
    try:
        url = f"https://docs.google.com/spreadsheets/d/{SHEET_ID}/gviz/tq?tqx=out:csv&sheet={sheet_name}"
        headers = {'User-Agent': 'Mozilla/5.0'}
        req = urllib.request.Request(url, headers=headers)
        response = urllib.request.urlopen(req)
        data = response.read().decode('utf-8')
        
        lines = data.strip().split('\n')
        result = []
        for line in lines:
            parts = []
            current = ''
            in_quotes = False
            for char in line:
                if char == '"' and not in_quotes:
                    in_quotes = True
                elif char == '"' and in_quotes:
                    in_quotes = False
                elif char == ',' and not in_quotes:
                    parts.append(current.strip())
                    current = ''
                else:
                    current += char
            parts.append(current.strip())
            result.append(parts)
        return result
    except Exception as e:
        print(f"Error reading {sheet_name}: {e}")
        return None

# ============ SEND EMAIL ============

def send_email(subject, body):
    try:
        msg = MIMEMultipart()
        msg['From'] = GMAIL_USER
        msg['To'] = ALERT_EMAIL
        msg['Subject'] = subject
        msg.attach(MIMEText(body, 'plain'))
        
        server = smtplib.SMTP('smtp.gmail.com', 587)
        server.starttls()
        server.login(GMAIL_USER, GMAIL_PASSWORD)
        server.send_message(msg)
        server.quit()
        return True
    except Exception as e:
        print(f"Email failed: {e}")
        return False

# ============ MAIN MATCH LOGIC ============

def run_match(run_number):
    print(f"\n{'='*70}")
    print(f"Run #{run_number} at {datetime.now().strftime('%H:%M:%S')}")
    print(f"{'='*70}")
    
    print("Reading Google Sheets...")
    
    po_data = read_sheet("PO")
    dn_data = read_sheet("DeliveryNote")
    inv_data = read_sheet("Invoice")
    
    if not po_data or len(po_data) <= 1:
        print("No PO data found!")
        return False
    
    total_rows = len(po_data) - 1
    print(f"PO: {total_rows} rows")
    if dn_data:
        print(f"DeliveryNote: {len(dn_data)-1} rows")
    if inv_data:
        print(f"Invoice: {len(inv_data)-1} rows")
    
    # Build lookup maps
    dn_map = {}
    if dn_data:
        for row in dn_data[1:]:
            if len(row) >= 4:
                key = row[1] + "|" + row[2]
                dn_map[key] = row[3]
    
    inv_map = {}
    if inv_data:
        for row in inv_data[1:]:
            if len(row) >= 5:
                key = row[1] + "|" + row[2]
                inv_map[key] = {'qty': row[3], 'price': row[4]}
    
    mismatches = []
    matched = 0
    
    print("\nAnalyzing...\n")
    
    # Process each PO line
    for idx, row in enumerate(po_data[1:], 1):
        if idx % 100 == 0:
            print(f"Progress: {idx}/{total_rows} ({int(idx/total_rows*100)}%)")
        
        if len(row) < 5:
            continue
        
        po_num = row[0]
        item = row[1]
        ordered = row[3]
        price = row[4]
        key = po_num + "|" + item
        
        received = dn_map.get(key, "MISSING")
        invoice = inv_map.get(key, {'qty': 'MISSING', 'price': 'MISSING'})
        
        notes = []
        is_mismatch = False
        
        # Check delivery note
        if received == "MISSING":
            notes.append("No delivery")
            is_mismatch = True
        elif str(received) != str(ordered):
            notes.append(f"Qty: {ordered} vs {received}")
            is_mismatch = True
        
        # Check invoice
        if invoice['qty'] == "MISSING":
            notes.append("No invoice")
            is_mismatch = True
        else:
            if str(invoice['qty']) != str(ordered):
                notes.append(f"Inv qty: {ordered} vs {invoice['qty']}")
                is_mismatch = True
            if str(invoice['price']) != str(price):
                notes.append(f"Price: {price} vs {invoice['price']}")
                is_mismatch = True
        
        if is_mismatch:
            mismatches.append({
                'po': po_num,
                'item': item,
                'ordered': ordered,
                'received': received,
                'invoiced': invoice['qty'],
                'price': price,
                'inv_price': invoice['price'],
                'notes': '; '.join(notes)
            })
        else:
            matched += 1
    
    total = len(po_data) - 1
    mismatch_count = len(mismatches)
    
    # Show summary
    print("\n" + "="*70)
    print("SUMMARY")
    print("="*70)
    print(f"Total PO Lines:   {total}")
    print(f"Matched:          {matched}")
    print(f"Mismatches:       {mismatch_count}")
    print(f"Match Rate:       {round((matched/total)*100, 1) if total > 0 else 0}%")
    print("="*70 + "\n")
    
    # Send email with all mismatches
    if mismatch_count > 0:
        print(f"Sending email with {mismatch_count} mismatches...")
        
        # Build email body
        body = f"""
3-WAY MATCH REPORT - RUN #{run_number}
================================

Time: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}

Summary:
- Total PO Lines: {total}
- Matched: {matched}
- Mismatches: {mismatch_count}
- Match Rate: {round((matched/total)*100, 1) if total > 0 else 0}%

ALL MISMATCHES:
"""
        for m in mismatches:
            body += f"""
--------------------------------
PO: {m['po']} | Item: {m['item']}
  Ordered: {m['ordered']} | Received: {m['received']} | Invoiced: {m['invoiced']}
  Issue: {m['notes']}
"""
        
        body += """
================================
Results saved to phone.
"""
        
        send_email(f"Run #{run_number}: {mismatch_count} mismatches", body)
    else:
        print("All matched! Sending all-clear email...")
        body = f"""
3-WAY MATCH REPORT - RUN #{run_number}
================================

Time: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}

ALL {total} PO lines matched perfectly!
No discrepancies found.
"""
        send_email(f"Run #{run_number}: ALL CLEAR!", body)
    
    # Save to file
    try:
        filename = f"/storage/emulated/0/match_results_run{run_number}_{datetime.now().strftime('%Y%m%d_%H%M')}.txt"
        with open(filename, 'w') as f:
            f.write(f"3-WAY MATCH - RUN #{run_number}\n")
            f.write(f"Date: {datetime.now().strftime('%Y-%m-%d %H:%M')}\n")
            f.write(f"Total: {total} | Matched: {matched} | Mismatches: {mismatch_count}\n\n")
            for m in mismatches:
                f.write(f"{m['po']} | {m['item']} | {m['notes']}\n")
        print(f"Saved to: {filename}")
    except:
        pass
    
    return True

# ============ RUN ============

if __name__ == "__main__":
    print("3-Way Match System")
    print("="*70)
    print(f"From: {GMAIL_USER}")
    print(f"To: {ALERT_EMAIL}")
    print(f"Runs: {TOTAL_RUNS}, {RUN_INTERVAL}s apart")
    print("="*70)
    print("\nPress Ctrl+C to stop\n")
    
    for run in range(1, TOTAL_RUNS + 1):
        run_match(run)
        
        if run < TOTAL_RUNS:
            print(f"\nWaiting {RUN_INTERVAL} seconds...")
            time.sleep(RUN_INTERVAL)
    
    print("\nAll done! Check your email.")
